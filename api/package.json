{
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "prisma generate --schema src/database/prisma/schema.prisma",
    "db:validate": "prisma validate --schema src/database/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema src/database/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema src/database/prisma/schema.prisma",
    "db:seed": "tsx src/database/prisma/seed.ts",
    "db:studio": "prisma studio --schema src/database/prisma/schema.prisma"
  },
  "packageManager": "pnpm@10.12.1",
  "keywords": [],
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prisma": "^6.19.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fastify/autoload": "^6.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^7.0.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/multipart": "^10.0.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "fastify-type-provider-zod": "^6.1.0",
    "ioredis": "5.11.1",
    "zod": "^4.4.3"
  }
}
