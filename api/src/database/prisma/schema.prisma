generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Locale {
  SQ
  EN
}

enum DocumentType {
  PURCHASE_INVOICE
  SALES_INVOICE
  FISCAL_RECEIPT
  CREDIT_NOTE
  UNKNOWN
}

enum DocumentDirection {
  PURCHASE
  SALE
  UNKNOWN
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  REVIEW_REQUIRED
  APPROVED
  AUTO_POSTED
  REJECTED
  FAILED
}

enum UploadSource {
  OWNER_CAMERA
  OWNER_FILE
  ACCOUNTANT_BATCH
}

enum BookType {
  PURCHASE
  SALE
}

enum TaxPeriodStatus {
  OPEN
  CLOSED
  EXPORTED
}

enum ExportType {
  PURCHASE_BOOK
  SALES_BOOK
  VAT_RECONCILIATION
  DOCUMENT_ARCHIVE
}

enum ExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum ActorType {
  ACCOUNTANT
  BUSINESS_OWNER
  SYSTEM
}

enum NotificationType {
  REVIEW_REQUIRED
  PROCESSING_FAILED
  DUPLICATE_DETECTED
  EXPORT_COMPLETED
  TAX_PERIOD_REMINDER
  CREDENTIAL_RESET
  SYSTEM
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String?   @unique
  username           String    @unique
  passwordHash       String    @map("password_hash")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  isActive           Boolean   @default(true) @map("is_active")
  locale             Locale    @default(SQ)
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  accountantProfile    Accountant?
  businessOwnerProfile BusinessOwner?
  roles                UserRole[]
  refreshSessions      RefreshSession[]
  notifications        Notification[]
  uploadedDocuments    Document[]       @relation("DocumentUploader")
  approvedBookEntries  BookEntry[]      @relation("BookEntryApprover")
  requestedExports     Export[]         @relation("ExportRequester")
  auditEvents          AuditEvent[]     @relation("AuditActor")

  @@index([isActive])
  @@map("users")
}

model Accountant {
  userId    String @id @map("user_id") @db.Uuid
  firstName String @map("first_name")
  lastName  String @map("last_name")

  user       User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  businesses Business[]

  @@map("accountants")
}

model Business {
  id             String   @id @default(uuid()) @db.Uuid
  accountantId   String   @map("accountant_id") @db.Uuid
  name           String
  fiscalNumber   String   @map("fiscal_number")
  vatNumber      String?  @map("vat_number")
  registrationNo String?  @map("registration_no")
  address        String?
  locale         Locale   @default(SQ)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  accountant    Accountant     @relation(fields: [accountantId], references: [userId], onDelete: Restrict)
  owner         BusinessOwner?
  documents     Document[]
  taxPeriods    TaxPeriod[]
  exports       Export[]
  auditEvents   AuditEvent[]
  notifications Notification[]

  @@unique([accountantId, fiscalNumber])
  @@index([accountantId])
  @@map("businesses")
}

model BusinessOwner {
  userId             String    @id @map("user_id") @db.Uuid
  businessId         String    @unique @map("business_id") @db.Uuid
  credentialsShownAt DateTime? @map("credentials_shown_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("business_owners")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  name        String
  description String?
  isSystem    Boolean  @default(false) @map("is_system")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  code        String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roles RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  grantedAt    DateTime @default(now()) @map("granted_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model RefreshSession {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  familyId  String    @default(uuid()) @map("family_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt])
  @@index([familyId])
  @@map("refresh_sessions")
}

model Document {
  id               String            @id @default(uuid()) @db.Uuid
  businessId       String            @map("business_id") @db.Uuid
  uploadedByType   ActorType         @map("uploaded_by_type")
  uploadedById     String?           @map("uploaded_by_id") @db.Uuid
  originalFileName String            @map("original_file_name")
  storageKey       String            @map("storage_key")
  mimeType         String            @map("mime_type")
  sizeBytes        BigInt            @map("size_bytes")
  contentHash      String            @map("content_hash")
  uploadSource     UploadSource      @map("upload_source")
  type             DocumentType      @default(UNKNOWN)
  direction        DocumentDirection @default(UNKNOWN)
  status           DocumentStatus    @default(UPLOADED)
  duplicateOfId    String?           @map("duplicate_of_id") @db.Uuid
  processingError  Json?             @map("processing_error")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Restrict)
  uploadedBy    User?          @relation("DocumentUploader", fields: [uploadedById], references: [id], onDelete: Restrict)
  duplicateOf   Document?      @relation("DocumentDuplicates", fields: [duplicateOfId], references: [id], onDelete: SetNull)
  duplicates    Document[]     @relation("DocumentDuplicates")
  pages         DocumentPage[]
  extractions   Extraction[]
  bookEntry     BookEntry?
  auditEvents   AuditEvent[]
  notifications Notification[]

  @@index([businessId, status])
  @@index([businessId, contentHash])
  @@index([uploadedById])
  @@map("documents")
}

model DocumentPage {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  pageNumber Int      @map("page_number")
  storageKey String   @map("storage_key")
  rotation   Int      @default(0)
  groupKey   String?  @map("group_key")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, pageNumber])
  @@map("document_pages")
}

model Extraction {
  id                String   @id @default(uuid()) @db.Uuid
  documentId        String   @map("document_id") @db.Uuid
  provider          String
  providerVersion   String?  @map("provider_version")
  normalizedFields  Json     @map("normalized_fields")
  originalFields    Json     @map("original_fields")
  fieldConfidences  Json     @map("field_confidences")
  overallConfidence Decimal  @map("overall_confidence") @db.Decimal(5, 4)
  rawProviderOutput Json?    @map("raw_provider_output")
  validationErrors  Json?    @map("validation_errors")
  processingErrors  Json?    @map("processing_errors")
  isCurrent         Boolean  @default(true) @map("is_current")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  document  Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  bookEntry BookEntry?

  @@index([documentId, isCurrent])
  @@map("extractions")
}

model TaxPeriod {
  id         String          @id @default(uuid()) @db.Uuid
  businessId String          @map("business_id") @db.Uuid
  startsOn   DateTime        @map("starts_on") @db.Date
  endsOn     DateTime        @map("ends_on") @db.Date
  status     TaxPeriodStatus @default(OPEN)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Restrict)
  bookEntries   BookEntry[]
  exports       Export[]
  notifications Notification[]

  @@unique([businessId, startsOn, endsOn])
  @@index([businessId, status])
  @@map("tax_periods")
}

model BookEntry {
  id                  String    @id @default(uuid()) @db.Uuid
  documentId          String    @unique @map("document_id") @db.Uuid
  extractionId        String    @unique @map("extraction_id") @db.Uuid
  taxPeriodId         String    @map("tax_period_id") @db.Uuid
  bookType            BookType  @map("book_type")
  entryData           Json      @map("entry_data")
  taxableTotal        Decimal   @map("taxable_total") @db.Decimal(18, 2)
  vatTotal            Decimal   @map("vat_total") @db.Decimal(18, 2)
  grandTotal          Decimal   @map("grand_total") @db.Decimal(18, 2)
  currency            String    @default("EUR") @db.VarChar(3)
  automaticallyPosted Boolean   @default(false) @map("automatically_posted")
  approvedById        String?   @map("approved_by_id") @db.Uuid
  approvedAt          DateTime? @map("approved_at")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  document   Document   @relation(fields: [documentId], references: [id], onDelete: Restrict)
  extraction Extraction @relation(fields: [extractionId], references: [id], onDelete: Restrict)
  taxPeriod  TaxPeriod  @relation(fields: [taxPeriodId], references: [id], onDelete: Restrict)
  approvedBy User?      @relation("BookEntryApprover", fields: [approvedById], references: [id], onDelete: Restrict)

  @@index([taxPeriodId, bookType])
  @@index([approvedById])
  @@map("book_entries")
}

model Export {
  id             String       @id @default(uuid()) @db.Uuid
  businessId     String       @map("business_id") @db.Uuid
  taxPeriodId    String?      @map("tax_period_id") @db.Uuid
  requestedById  String       @map("requested_by_id") @db.Uuid
  type           ExportType
  status         ExportStatus @default(PENDING)
  storageKey     String?      @map("storage_key")
  mappingVersion String?      @map("mapping_version")
  error          Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  completedAt    DateTime?    @map("completed_at")

  business      Business       @relation(fields: [businessId], references: [id], onDelete: Restrict)
  taxPeriod     TaxPeriod?     @relation(fields: [taxPeriodId], references: [id], onDelete: Restrict)
  requestedBy   User           @relation("ExportRequester", fields: [requestedById], references: [id], onDelete: Restrict)
  notifications Notification[]

  @@index([businessId, createdAt])
  @@index([requestedById])
  @@map("exports")
}

model TaxMapping {
  id            String   @id @default(uuid()) @db.Uuid
  name          String
  version       String   @unique
  effectiveOn   DateTime @map("effective_on") @db.Date
  configuration Json
  isActive      Boolean  @default(false) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("tax_mappings")
}

model AuditEvent {
  id         String    @id @default(uuid()) @db.Uuid
  businessId String?   @map("business_id") @db.Uuid
  documentId String?   @map("document_id") @db.Uuid
  actorType  ActorType @map("actor_type")
  actorId    String?   @map("actor_id") @db.Uuid
  action     String
  entityType String    @map("entity_type")
  entityId   String?   @map("entity_id") @db.Uuid
  metadata   Json?
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  occurredAt DateTime  @default(now()) @map("occurred_at")

  business Business? @relation(fields: [businessId], references: [id], onDelete: Restrict)
  document Document? @relation(fields: [documentId], references: [id], onDelete: Restrict)
  actor    User?     @relation("AuditActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([businessId, occurredAt])
  @@index([actorId, occurredAt])
  @@index([entityType, entityId])
  @@map("audit_events")
}

model Notification {
  id          String           @id @default(uuid()) @db.Uuid
  recipientId String           @map("recipient_id") @db.Uuid
  businessId  String?          @map("business_id") @db.Uuid
  documentId  String?          @map("document_id") @db.Uuid
  taxPeriodId String?          @map("tax_period_id") @db.Uuid
  exportId    String?          @map("export_id") @db.Uuid
  type        NotificationType
  titleKey    String           @map("title_key")
  messageKey  String           @map("message_key")
  parameters  Json?
  readAt      DateTime?        @map("read_at")
  expiresAt   DateTime?        @map("expires_at")
  createdAt   DateTime         @default(now()) @map("created_at")

  recipient User       @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  business  Business?  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  document  Document?  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  taxPeriod TaxPeriod? @relation(fields: [taxPeriodId], references: [id], onDelete: Cascade)
  export    Export?    @relation(fields: [exportId], references: [id], onDelete: Cascade)

  @@index([recipientId, readAt, createdAt])
  @@index([businessId, createdAt])
  @@map("notifications")
}
